---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrap">
    <div class="footer-row">
      <span class="footer-links muted">
        © {year} Marco Fago ·
        <a href="https://github.com/marfago-labs">marfago-labs</a> ·
        <a href="https://www.linkedin.com/in/marco-fago/">LinkedIn</a> ·
        <a href="https://github.com/marfago">@marfago</a>
      </span>
      <p class="footer-meta" role="note">
        Personal views only; not those of any employer, client, or organization.
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 3rem;
    border-top: 1px solid var(--border);
    padding: 1.25rem 0 2rem;
  }
  .wrap {
    max-width: var(--wide);
    margin: 0 auto;
    padding: 0 1.25rem;
  }
  .footer-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1.5rem;
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.45;
  }
  .footer-links {
    flex-shrink: 0;
  }
  .footer-meta {
    margin: 0;
    flex-shrink: 1;
    text-align: right;
    font-size: 0.78rem;
    color: var(--muted);
    max-width: 28rem;
  }
  @media (max-width: 720px) {
    .footer-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
    .footer-meta {
      text-align: left;
      max-width: none;
    }
  }
</style>
