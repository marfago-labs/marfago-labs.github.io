---
import { formatPageStamp } from "../lib/pageMeta";

interface Props {
  version: string;
  published?: Date;
  lastUpdated: Date;
  class?: string;
}

const { version, published, lastUpdated, class: className = "" } = Astro.props;
const stamp = formatPageStamp({ version, published, lastUpdated });
---

<p class:list={["muted", "page-stamp", className]}>{stamp}</p>

<style>
  .page-stamp {
    margin: 0;
    font-size: 0.85rem;
  }
</style>
