---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageMetaRow from "../../components/PageMetaRow.astro";
import { repoPages } from "../../data/projects";
import { sitePageMeta } from "../../data/site-pages";
import { pageReadingLabel } from "../../lib/readingTime";

const meta = sitePageMeta.ner;

const nerReadingSource = [
  "A production-style path from gold generation to benchmark-ready datasets to measured backend comparison.",
  "LLM span offsets hallucinate. Strict vs relaxed F1 disagree on salient gold.",
  "Engineering bar. Gold JSONL validated on every PR. YAML-driven benchmarks.",
  "ner-gold-generator ner-dataset ner-detector",
].join(" ");
const nerMetaLabel = pageReadingLabel("NER pipeline", nerReadingSource);
---

<BaseLayout
  title="NER evaluation pipeline"
  description="Gold generation, validated datasets, and backend benchmarks."
>
  <div class="prose">
    <p class="muted"><a href="/projects/">← Projects</a></p>
    <PageMetaRow
      label={nerMetaLabel}
      version={meta.version}
      published={meta.published}
      lastUpdated={meta.lastUpdated}
    />
    <h1>NER evaluation pipeline</h1>
    <p class="lead">
      A production-style path from gold generation to benchmark-ready datasets
      to measured backend comparison — built because I could not trust NER
      quality without numbers.
    </p>

    <div class="pipeline card">
      <code>ner-gold-generator</code> → <code>ner-dataset</code> →
      <code>ner-detector</code>
    </div>

    <h2>Hard problems</h2>
    <ul>
      <li>LLM span offsets hallucinate — entity-first planning + deterministic anchoring</li>
      <li>Strict vs relaxed F1 disagree on salient gold — Doc F1 as primary metric</li>
      <li>LLM quality vs BERT latency — measured per document, not assumed</li>
    </ul>

    <h2>Engineering bar</h2>
    <ul>
      <li>≥95% test coverage, typed Python, pre-commit, Gitleaks in CI</li>
      <li>Gold JSONL validated on every PR (exact spans, unique anchoring)</li>
      <li>YAML-driven benchmarks; HTML reports from CI</li>
    </ul>

    <h2>Repos &amp; live reports</h2>
    <p>
      All three repos are public. CI publishes validators and GitHub Pages dashboards
      you can re-run locally or challenge in a PR.
    </p>
    <ul>
      <li><a href="https://github.com/marfago-labs/ner-gold-generator">ner-gold-generator</a></li>
      <li>
        <a href="https://github.com/marfago-labs/ner-dataset">ner-dataset</a>
        — Pages dashboard:
        <a href={repoPages.nerDataset} target="_blank" rel="noopener">{repoPages.nerDataset} ↗</a>
      </li>
      <li>
        <a href="https://github.com/marfago-labs/ner-detector">ner-detector</a>
        — Pages benchmark:
        <a href={repoPages.nerDetector} target="_blank" rel="noopener">{repoPages.nerDetector} ↗</a>
      </li>
    </ul>

    <h2>Story</h2>
    <p>
      Read the full arc in
      <a href="/blog/series-index/">Building an Evaluation Lab by Accident</a>.
    </p>
  </div>
</BaseLayout>

<style>
  .pipeline {
    font-size: 0.95rem;
    margin: 1.5rem 0;
  }
</style>
