---
import BaseLayout from "./BaseLayout.astro";
import MermaidInit from "../components/MermaidInit.astro";
import PageMetaRow from "../components/PageMetaRow.astro";
import { getPostMetaLabel } from "../lib/blog";
import { formatReadingTime } from "../lib/readingTime";

interface Props {
  title: string;
  description: string;
  date: Date;
  lastUpdated: Date;
  version: string;
  order: number;
  series?: string;
  cover?: string;
  coverAlt?: string;
  readingMinutes: number;
}

const {
  title,
  description,
  date,
  lastUpdated,
  version,
  order,
  series,
  cover,
  coverAlt,
  readingMinutes,
} = Astro.props;
const metaLabel = getPostMetaLabel(order, series);
const readingLabel = formatReadingTime(readingMinutes);
---

<BaseLayout title={title} description={description}>
  <article class="prose">
    <PageMetaRow
      label={`${metaLabel} · ${readingLabel}`}
      version={version}
      published={date}
      lastUpdated={lastUpdated}
      tightBelow={!!cover}
    />
    {
      cover && (
        <figure class="cover">
          <img src={cover} alt={coverAlt ?? title} width="1200" height="675" loading="eager" />
        </figure>
      )
    }
    <slot />
    <hr />
    <p><a href="/blog/">← All posts</a></p>
  </article>
  <MermaidInit />
</BaseLayout>

<style>
  .cover {
    margin: 0 0 0.5rem;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: 0 4px 20px rgba(26, 26, 24, 0.06);
  }
  .cover img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }
  hr {
    margin: 2.5rem 0 1rem;
    border: none;
    border-top: 1px solid var(--border);
  }
</style>
