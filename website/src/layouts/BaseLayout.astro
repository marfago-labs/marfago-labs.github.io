---
import GoogleAnalytics from "../components/GoogleAnalytics.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Principal AI engineering lab — evidence over vibes.",
} = Astro.props;
const fullTitle = title === "marfago labs" ? title : `${title} · marfago labs`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="Marco Fago" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <GoogleAnalytics />
  </head>
  <body>
    <Header />
    <main class="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  .main {
    max-width: var(--wide);
    margin: 0 auto;
    padding: 2.5rem 1.25rem 3rem;
  }
</style>
