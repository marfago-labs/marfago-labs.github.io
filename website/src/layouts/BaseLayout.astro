---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PageStamp from "../components/PageStamp.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  version?: string;
  published?: Date;
  lastUpdated?: Date;
}

const {
  title,
  description = "Principal AI engineering lab — evidence over vibes.",
  version,
  published,
  lastUpdated,
} = Astro.props;
const fullTitle = title === "marfago labs" ? title : `${title} · marfago labs`;
const showStamp = version && lastUpdated;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="Marco Fago" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
  </head>
  <body>
    <Header />
    <main class="main">
      <slot />
      {
        showStamp && (
          <PageStamp
            class="layout-stamp"
            version={version}
            published={published}
            lastUpdated={lastUpdated}
          />
        )
      }
    </main>
    <Footer />
  </body>
</html>

<style>
  .main {
    max-width: var(--wide);
    margin: 0 auto;
    padding: 2.5rem 1.25rem 3rem;
  }
  :global(.layout-stamp) {
    margin-top: 2.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }
</style>
